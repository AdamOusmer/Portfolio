---
import Magnetic from './Magnetic.astro';
---

<back-to-top-button style="display: contents;">
    <Magnetic pull={0.2} targetSelector=".back-to-top-inner" class="back-to-top-wrapper">
    <button class="back-to-top" type="button" aria-label="Back to top" hidden>
        <span class="back-to-top-inner">
            <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <line x1="12" y1="19" x2="12" y2="5" />
                <polyline points="5 12 12 5 19 12" />
            </svg>
            <span class="back-to-top-label">Top</span>
        </span>
        </button>
    </Magnetic>
</back-to-top-button>

<style>
    :global(.back-to-top-wrapper) {
        position: fixed;
        bottom: 1.75rem;
        right: 1.75rem;
        z-index: 900;
        display: inline-flex;
    }

    .back-to-top {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1.25rem;
        border-radius: 999px;
        font-family: "Space Mono", monospace;
        font-size: 14px;
        font-weight: 500;

        color: var(--text-main);
        background: rgba(11, 15, 25, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        outline: 1.5px solid var(--border-color);

        overflow: hidden;

        opacity: 0;
        transform: translateY(20px);
        pointer-events: none;

        transition:
            opacity 0.35s ease,
            transform 0.35s ease,
            color 0.25s,
            outline-color 0.25s;
    }

    .back-to-top.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .back-to-top-inner {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .back-to-top::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: var(--surface-color);
        transform: translateY(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 0;
    }

    .back-to-top:hover {
        outline-color: var(--primary-green);
        color: var(--primary-green);
    }

    .back-to-top:hover::before {
        transform: translateY(0);
    }

    .back-to-top:active {
        transform: translateY(0) scale(0.97);
    }

    .back-to-top:focus-visible {
        outline: 2px solid var(--primary-green);
        outline-offset: 3px;
    }

    @media (max-width: 600px) {
        .back-to-top {
            bottom: 1rem;
            right: 1rem;
            padding: 0.6rem 1rem;
        }

        .back-to-top-label {
            display: none;
        }
    }
</style>

<script>
    import { lenis } from "../../scripts/scroll.js";

    class BackToTopButton extends HTMLElement {
        private btn: HTMLButtonElement | null = null;
        private readonly threshold = 600;

        connectedCallback() {
            setTimeout(() => {
                this.btn = this.querySelector(".back-to-top");
                if (!this.btn) return;

                this.btn.addEventListener("click", () => {
                    if (lenis && typeof lenis.scrollTo === "function") {
                        lenis.scrollTo(0);
                    } else {
                        window.scrollTo({ top: 0, behavior: "smooth" });
                    }
                });

                window.addEventListener("scroll", this.update, { passive: true });
                this.update();
            }, 0);
        }

        disconnectedCallback() {
            window.removeEventListener("scroll", this.update);
        }

        private update = (): void => {
            if (!this.btn) return;
            const shouldShow = window.scrollY > this.threshold;
            this.btn.classList.toggle("visible", shouldShow);
            this.btn.hidden = false;
        };
    }

    if (!customElements.get('back-to-top-button')) {
        customElements.define('back-to-top-button', BackToTopButton);
    }
</script>
