---
// Reusable Page Entrance component to encapsulate entrance animations
---

<page-entrance style="display: contents;">
    <slot />
</page-entrance>

<script>
    import { animate, cubicBezier } from "motion";

    class PageEntrance extends HTMLElement {
        connectedCallback() {
            setTimeout(() => {
                const smooth = cubicBezier(0.25, 1, 0.5, 1);
                const elastic = cubicBezier(0.34, 1.56, 0.64, 1);

                const reveal = this.querySelector(".page-reveal");
                const titleLine = this.querySelector(".page-title-line");
                const staggerEls = this.querySelectorAll(".page-stagger");
                const slideEls = this.querySelectorAll(".page-slide");

                if (reveal) {
                    animate(
                        reveal,
                        { clipPath: ["inset(45% 0 45% 0)", "inset(0% 0 0% 0)"] },
                        { duration: 0.9, delay: 0.2, easing: smooth }
                    );
                }

                if (titleLine) {
                    animate(
                        titleLine,
                        { transform: ["translateX(-50%) scaleX(0)", "translateX(-50%) scaleX(1)"] },
                        { duration: 0.5, delay: 0.7, easing: elastic }
                    );
                }

                staggerEls.forEach((el, i) => {
                    animate(
                        el,
                        { opacity: [0, 1], transform: ["translateY(25px)", "translateY(0)"] },
                        { duration: 0.7, delay: 0.5 + i * 0.15, easing: smooth }
                    );
                });

                slideEls.forEach((el, i) => {
                    animate(
                        el,
                        { opacity: [0, 1], transform: ["translateX(-20px)", "translateX(0)"] },
                        { duration: 0.6, delay: 0.7 + i * 0.12, easing: smooth }
                    );
                });
            }, 0);
        }
    }

    if (!customElements.get('page-entrance')) {
        customElements.define('page-entrance', PageEntrance);
    }
</script>
