---
import type { CollectionEntry } from 'astro:content';
import Button from './buttons/Button.astro';
import Magnetic from './Magnetic.astro';
import { m } from '../../paraglide/messages.js';
import { getLocale, localizeHref } from '../../paraglide/runtime.js';
import { asLocale } from '../../i18n/config';
import { localized } from '../../i18n/localized';

interface Props {
    project: CollectionEntry<'projects'>;
    index?: number;
}

const { project, index = 0 } = Astro.props;
const loc = asLocale(getLocale());
const title = localized(project.data, loc, 'title');
const description = localized(project.data, loc, 'description');
---

<article class:list={["scroll-reveal", { featured: project.data.featured }]} style={`--index: ${index}`}>
    <div>
        <time>{project.data.year}</time>
        <h3>{title}</h3>
        <p>{description}</p>

        <footer>
            <div>
                {project.data.tags.map((tag) => (
                    <span>{tag}</span>
                ))}
            </div>

            <nav>
                {project.data.websiteUrl && (
                    <Magnetic pull={0.2}>
                        <a href={project.data.websiteUrl} rel="noopener noreferrer" target="_blank" aria-label={m.project_aria_website()}>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="12" cy="12" r="10"></circle>
                                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                            </svg>
                        </a>
                    </Magnetic>
                )}
                {project.data.githubUrl && (
                    <Magnetic pull={0.2}>
                        <a href={project.data.githubUrl} rel="noopener noreferrer" target="_blank" aria-label={m.project_aria_github()}>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                            </svg>
                        </a>
                    </Magnetic>
                )}
                {project.data.docsSlug && (
                    <Button href={localizeHref(`/${project.data.docsSlug}/`)} text={m.project_btn_docs()} />
                )}
                {project.data.blogSlug && (
                    <Button href={localizeHref(`/blog/${project.data.blogSlug}`)} text={m.project_btn_learn_more()} />
                )}
            </nav>
        </footer>
    </div>
</article>

<style>
    article {
        background: rgba(17, 24, 39, 0.4);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        overflow: hidden;
    }

    article.featured {
        border-color: rgba(16, 185, 129, 0.25);
        box-shadow: 0 0 20px -5px rgba(16, 185, 129, 0.15);
    }

    article:hover {
        transform: translateY(-6px);
        border-color: rgba(16, 185, 129, 0.4);
        box-shadow: 0 15px 35px -15px rgba(16, 185, 129, 0.3);
    }

    article > div {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    time {
        font-family: 'Space Mono', monospace;
        color: var(--primary-green);
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    h3 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.4rem;
        color: var(--text-main);
        margin: 0 0 0.75rem 0;
    }

    p {
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
        flex-grow: 1;
    }

    footer {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    footer > div {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    footer > div > span {
        display: inline-block;
        padding: 0.25rem 0.65rem;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--text-muted);
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 999px;
    }

    footer > nav {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    footer > nav > a {
        color: var(--text-muted);
        transition: color 0.2s ease;
        display: inline-flex;
    }

    footer > nav > a:hover {
        color: var(--text-main);
    }
</style>
