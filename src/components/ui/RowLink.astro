---
interface SecondaryLink {
    href: string;
    kind: 'website' | 'github' | 'blog';
    ariaLabel: string;
    external?: boolean;
}

interface Props {
    href: string;
    label: string;
    year?: string | number;
    links?: SecondaryLink[];
    ariaLabel?: string;
    external?: boolean;
    class?: string;
}

const { href, label, year, links = [], ariaLabel, external = false, class: className } = Astro.props;
---

<div class:list={["row", className]}>
    <a
        class="row-link"
        href={href}
        aria-label={ariaLabel || label}
        rel={external ? "noopener noreferrer" : undefined}
        target={external ? "_blank" : undefined}
    >
        <span class="title-wrap">
            {year && <time>{year}</time>}
            <span class="title">{label}</span>
        </span>
        <span class="arrow" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
        </span>
    </a>

    {links.length > 0 && (
        <nav class="links" aria-label={`${label} external links`}>
            {links.map((link) => {
                const isExt = link.external !== undefined ? link.external : (link.kind === 'website' || link.kind === 'github');
                return (
                    <a
                        href={link.href}
                        aria-label={link.ariaLabel}
                        title={link.kind.charAt(0).toUpperCase() + link.kind.slice(1)}
                        rel={isExt ? "noopener noreferrer" : undefined}
                        target={isExt ? "_blank" : undefined}
                    >
                        {link.kind === 'website' && (
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="2" y1="12" x2="22" y2="12"></line>
                                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                            </svg>
                        )}
                        {link.kind === 'github' && (
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                            </svg>
                        )}
                        {link.kind === 'blog' && (
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                            </svg>
                        )}
                    </a>
                );
            })}
        </nav>
    )}
</div>

<style>
    .row {
        position: relative;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        border-bottom: 1px solid var(--border-color);
        transition: color 0.3s ease;
    }

    .row::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--primary-green);
        transition: width 0.4s ease;
    }

    .row:hover::after {
        width: 100%;
    }

    .row:hover {
        color: var(--primary-green);
    }

    /* Primary link fills the row; ::after creates the invisible click overlay */
    .row-link {
        flex: 1;
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.5rem 0;
        color: var(--text-main);
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.4rem;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .row-link::after {
        content: "";
        position: absolute;
        inset: 0;
    }

    .row-link:focus-visible {
        outline: none;
    }

    .row-link:focus-visible::after {
        outline: 2px solid var(--primary-green);
        outline-offset: 4px;
    }

    .row:hover .row-link {
        color: var(--primary-green);
    }

    .title-wrap {
        display: inline-flex;
        align-items: baseline;
        gap: 1rem;
        min-width: 0;
    }

    time {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        color: var(--primary-green);
        letter-spacing: 1px;
        flex-shrink: 0;
        transition: color 0.35s ease;
    }

    .title {
        color: inherit;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .arrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: inherit;
        flex-shrink: 0;
        opacity: 0;
        transform: translateX(-5px);
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .row:hover .arrow {
        opacity: 1;
        transform: translateX(0);
    }

    /* Secondary action links sit above the row-link overlay */
    .links {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
    }

    .links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        transition: color 0.25s ease, transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .links a:hover {
        color: var(--text-main);
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .row-link {
            font-size: 1.1rem;
        }
    }

    @media (max-width: 600px) {
        .row-link {
            padding: 1.15rem 0;
        }

        .title-wrap {
            gap: 0.75rem;
        }

        .links {
            gap: 0.75rem;
        }
    }
</style>
