---
import Layout from '../layouts/layout.astro';
import PageEntrance from '../components/ui/PageEntrance.astro';
import RowLink from '../components/ui/RowLink.astro';
---

<Layout title="Contact - Adam Ousmer" description="Reach out for internship opportunities, project collaborations, or a direct conversation.">
    <PageEntrance>
        <header>
        <div class="parallax" style="--parallax-speed: 0.3">
            <div class="page-reveal">
                <h1>Get in touch</h1>
                <span class="page-title-line"></span>
            </div>
            <p class="page-stagger">I am open to internship opportunities, project collaborations, and direct messages.</p>
        </div>
    </header>

    <main>
        <nav>
            <RowLink href="https://github.com/adamousmer" label="GitHub" external class="page-slide" />
            <RowLink href="https://www.linkedin.com/in/adam-ousmer/" label="LinkedIn" external class="page-slide" />
            <RowLink href="mailto:contact@adam-ousmer.dev" label="contact@adam-ousmer.dev" class="page-slide" />
        </nav>
    </main>
    </PageEntrance>
</Layout>
<style>
    header {
        position: relative;
        height: 50vh;
        min-height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
    }

    header > div {
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    header h1 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: clamp(3rem, 6vw, 4.5rem);
        color: var(--text-main);
        margin: 0 0 1rem 0;
    }

    header p {
        font-family: 'Space Mono', monospace;
        font-size: 1.1rem;
        color: var(--text-muted);
        max-width: 500px;
        margin: 0 auto;
        line-height: 1.6;
    }

    main {
        max-width: 700px;
        margin: 0 auto;
        padding: 0 2rem 8rem 2rem;
    }

    nav {
        display: flex;
        flex-direction: column;
        gap: 0;
    }
</style>
