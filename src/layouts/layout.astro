---
/**
 * If any external CDN scripts are added in the future, they must include
 * integrity="" and crossorigin="anonymous" attributes for subresource integrity.
 */

import Nav from "../components/layout/nav.astro";
import Footer from "../components/layout/Footer.astro";
import Nodes from "../components/layout/node.astro";

import { ClientRouter } from "astro:transitions";
import { getRelativeLocaleUrl } from "astro:i18n";
import "../styles/style.css";

import "@fontsource/space-grotesk/400.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";

import { asLocale, LOCALES, HREFLANG, HTML_LANG, OG_LOCALE, DEFAULT_LOCALE } from "../i18n/config";
import { m } from "../paraglide/messages.js";

interface Props {
    title: string;
    description?: string;
    image?: string;
}

const currentLocale = asLocale(Astro.currentLocale);

const {
    title,
    description = m.site_description_default(),
    image = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === `/${currentLocale}/`;

// Build the path WITHOUT any locale prefix, so we can re-emit it for every locale.
function stripLocalePrefix(pathname: string): string {
    for (const loc of LOCALES) {
        if (loc === DEFAULT_LOCALE) continue;
        if (pathname === `/${loc}` || pathname === `/${loc}/`) return '/';
        if (pathname.startsWith(`/${loc}/`)) return pathname.slice(`/${loc}`.length);
    }
    return pathname;
}
const basePath = stripLocalePrefix(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang={HTML_LANG[currentLocale]}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#0b0f19" />
        <meta http-equiv="X-Content-Type-Options" content="nosniff" />
        <meta name="referrer" content="strict-origin-when-cross-origin" />
        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <meta name="apple-mobile-web-app-title" content="Adam" />
        <link rel="manifest" href="/site.webmanifest" />
        <link rel="preload" as="font" type="font/woff2" crossorigin href="/_astro/space-grotesk-latin-400-normal.CJ-V5oYT.woff2" />
        <link rel="preload" as="font" type="font/woff2" crossorigin href="/_astro/space-mono-latin-400-normal.Rg4St2Dn.woff2" />

        <!-- Primary Meta Tags -->

        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={description} />
        <meta name="author" content="Adam Ousmer" />
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href={canonicalURL} />
        <link rel="sitemap" href="/sitemap-index.xml" />

        <!-- hreflang alternates -->
        {LOCALES.map((loc) => (
            <link
                rel="alternate"
                hreflang={HREFLANG[loc]}
                href={new URL(getRelativeLocaleUrl(loc, basePath), Astro.site)}
            />
        ))}
        <link
            rel="alternate"
            hreflang="x-default"
            href={new URL(getRelativeLocaleUrl(DEFAULT_LOCALE, basePath), Astro.site)}
        />

        <!-- Open Graph / Facebook -->

        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(image, Astro.url)} />
        <meta property="og:site_name" content="Adam Ousmer's Portfolio" />
        <meta property="og:locale" content={OG_LOCALE[currentLocale]} />
        {LOCALES.filter((loc) => loc !== currentLocale).map((loc) => (
            <meta property="og:locale:alternate" content={OG_LOCALE[loc]} />
        ))}

        <!-- Twitter -->

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(image, Astro.url)} />
        <meta name="twitter:creator" content="@itsmavey" />

        <!-- Structured Data -->
        {isHomepage && (
            <script type="application/ld+json" set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "Person",
                "name": "Adam Ousmer",
                "url": "https://adam-ousmer.dev",
                "sameAs": [
                    "https://github.com/AdamOusmer"
                ],
                "jobTitle": "Software Engineering Student",
                "alumniOf": {
                    "@type": "CollegeOrUniversity",
                    "name": "Concordia University"
                }
            })} />
        )}
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "Adam Ousmer",
            "url": "https://adam-ousmer.dev"
        })} />

        <slot name="head" />
        <ClientRouter />
    </head>
    <body>
        <Nodes />

        <Nav />

        <slot />

        <Footer />

        <script>
            import "../scripts/scroll.js";
            import "../scripts/easter-egg.js";
        </script>
    </body>
</html>
